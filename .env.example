TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# サービス設定
PORT=3001
CACHE_TTL_MS=60000      # タイムラインのキャッシュ時間（ミリ秒）
TIMELINE_COUNT=40       # 取得するツイート数

# Twitter 内部 API が変更された場合にここで query ID を上書きする
# 最新値は Twitter web の Network タブ → graphql/*/HomeLatestTimeline で確認
# HOME_TL_QUERY_ID=K0X1xbCZUjttdK8RazKAlw
# FAVORITE_QUERY_ID=lI07N6Otwv1PhnEgXILM7A
